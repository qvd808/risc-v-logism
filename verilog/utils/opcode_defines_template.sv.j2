// =============================================================================
// AUTOGENERATED - DO NOT EDIT MANUALLY
// Source: {{ source_file }}
// Generated: {{ now().strftime('%Y-%m-%dT%H:%M:%S') }}
// Instruction Set: {{ instruction_set }}
// =============================================================================
package opcode_defines;

  // ===========================================================================
  // Instruction Format Enum
  // ===========================================================================
  typedef enum logic [2:0] {
    FORMAT_R = 3'd0,  // Register:  funct7 | rs2 | rs1 | funct3 | rd | opcode
    FORMAT_I = 3'd1,  // Immediate: imm[11:0] | rs1 | funct3 | rd | opcode
    FORMAT_S = 3'd2,  // Store:     imm[11:5] | rs2 | rs1 | funct3 | imm[4:0] | opcode
    FORMAT_B = 3'd3,  // Branch:    imm[12|10:5] | rs2 | rs1 | funct3 | imm[4:1|11] | opcode
    FORMAT_U = 3'd4,  // Upper:     imm[31:12] | rd | opcode
    FORMAT_J = 3'd5,  // Jump:      imm[20|10:1|11|19:12] | rd | opcode
    FORMAT_UNKNOWN = 3'd7
  } instr_format_t;

  // ===========================================================================
  // OPCODE Enumerations (sorted by binary value)
  // ===========================================================================
  typedef enum logic [6:0] {
    {% for oe in opcode_enums %}
    OPCODE_{{ "%-12s" | format(oe.name) }} = 7'b{{ oe.value }}{% if not loop.last %},{% endif %}  // {{ oe.instructions | join(", ") }}
    {% endfor %}
  } opcode_t;

  // ===========================================================================
  // FUNCT3 Enumerations
  // ===========================================================================
  typedef enum logic [2:0] {
    {% for fe in funct3_enums %}
    {{ "%-20s" | format(fe.name) }} = 3'b{{ fe.value }}{% if not loop.last %},{% endif %}  // {{ fe.instructions | join(", ") }}
    {% endfor %}
  } funct3_t;

  // ===========================================================================
  // Instruction Properties
  // ===========================================================================
  {% for instr in instructions %}

  // {{ instr.name }}: {{ instr.description }}
  localparam logic [6:0]        {{ "%-12s" | format(instr.name + "_OPCODE") }} = 7'b{{ instr.encoding.opcode }};
  {% if instr.has_funct3 %}
  localparam logic [2:0]        {{ "%-12s" | format(instr.name + "_FUNCT3") }} = 3'b{{ instr.encoding.funct3 }};
  {% endif %}
  {% if instr.has_funct7 %}
  localparam logic [6:0]        {{ "%-12s" | format(instr.name + "_FUNCT7") }} = 7'b{{ instr.encoding.funct7 }};
  {% endif %}
  localparam instr_format_t     {{ "%-12s" | format(instr.name + "_FORMAT") }} = {{ instr.format }};
  {% endfor %}

  // ===========================================================================
  // Decode Helper Function
  // ===========================================================================
  function automatic instr_format_t get_format(input opcode_t op);
    case (op)
      {% for fc in format_cases %}
      OPCODE_{{ "%-12s" | format(fc.opcode_name) }}: return {{ fc.format }};
      {% endfor %}
      default: return FORMAT_I;
    endcase
  endfunction

endpackage

